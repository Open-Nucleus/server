{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": ["resourceType", "name", "gender"],
  "properties": {
    "resourceType": {
      "type": "string",
      "const": "Patient"
    },
    "name": {
      "type": "array",
      "minItems": 1
    },
    "gender": {
      "type": "string",
      "enum": ["male", "female", "other", "unknown"]
    }
  }
}
