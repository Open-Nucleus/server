{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": ["resourceType", "name", "gender", "birthDate"],
  "properties": {
    "resourceType": {
      "type": "string",
      "const": "Patient"
    },
    "name": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["family", "given"],
        "properties": {
          "family": {
            "type": "string",
            "minLength": 1
          },
          "given": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string"
            }
          }
        }
      }
    },
    "gender": {
      "type": "string",
      "enum": ["male", "female", "other", "unknown"]
    },
    "birthDate": {
      "type": "string",
      "minLength": 1
    }
  }
}
