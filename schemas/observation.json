{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": ["resourceType", "status", "code", "subject", "effectiveDateTime"],
  "$defs": {
    "Reference": {
      "type": "object",
      "required": ["reference"],
      "properties": {
        "reference": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "CodeableConcept": {
      "type": "object",
      "anyOf": [
        {
          "required": ["coding"],
          "properties": {
            "coding": {
              "type": "array",
              "minItems": 1
            }
          }
        },
        {
          "required": ["text"],
          "properties": {
            "text": {
              "type": "string",
              "minLength": 1
            }
          }
        }
      ]
    }
  },
  "properties": {
    "resourceType": {
      "type": "string",
      "const": "Observation"
    },
    "status": {
      "type": "string",
      "enum": ["registered", "preliminary", "final", "amended", "corrected", "cancelled", "entered-in-error"]
    },
    "code": {
      "$ref": "#/$defs/CodeableConcept"
    },
    "subject": {
      "$ref": "#/$defs/Reference"
    },
    "effectiveDateTime": {
      "type": "string",
      "minLength": 1
    }
  }
}
