{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": ["resourceType", "status", "code", "subject"],
  "$defs": {
    "Reference": {
      "type": "object",
      "required": ["reference"],
      "properties": {
        "reference": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "CodeableConcept": {
      "type": "object",
      "properties": {
        "coding": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "properties": {
              "code": { "type": "string" },
              "display": { "type": "string" }
            }
          }
        },
        "text": { "type": "string" }
      }
    }
  },
  "properties": {
    "resourceType": {
      "type": "string",
      "const": "Procedure"
    },
    "status": {
      "type": "string",
      "enum": ["preparation", "in-progress", "not-done", "on-hold", "stopped", "completed", "entered-in-error", "unknown"]
    },
    "code": {
      "$ref": "#/$defs/CodeableConcept"
    },
    "subject": {
      "$ref": "#/$defs/Reference"
    }
  }
}
