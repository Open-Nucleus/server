{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": ["resourceType", "status", "vaccineCode", "patient", "occurrenceDateTime"],
  "$defs": {
    "Reference": {
      "type": "object",
      "required": ["reference"],
      "properties": {
        "reference": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "CodeableConcept": {
      "type": "object",
      "properties": {
        "coding": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "properties": {
              "code": { "type": "string" },
              "display": { "type": "string" }
            }
          }
        },
        "text": { "type": "string" }
      }
    }
  },
  "properties": {
    "resourceType": {
      "type": "string",
      "const": "Immunization"
    },
    "status": {
      "type": "string",
      "enum": ["completed", "entered-in-error", "not-done"]
    },
    "vaccineCode": {
      "$ref": "#/$defs/CodeableConcept"
    },
    "patient": {
      "$ref": "#/$defs/Reference"
    },
    "occurrenceDateTime": {
      "type": "string",
      "minLength": 1
    }
  }
}
